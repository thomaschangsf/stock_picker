# Copy to config/secrets.env or repo-root .env (gitignored). Shell exports win over files.
# Full reference: docs/env.md  |  Quick status: uv run stock-picker doctor --symbol AAPL

# --- poc1 run ---
#OPENAI_API_KEY=
#STOCK_PICKER_OPENAI_MODEL=gpt-4o-mini
#STOCK_PICKER_PRICE_INPUT_PER_1M=0.15
#STOCK_PICKER_PRICE_OUTPUT_PER_1M=0.60

# --- phase2 adhoc (SEC + optional Finnhub; market = Parquet file, not a key) ---
#STOCK_PICKER_SEC_USER_AGENT="Your Name your.email@example.com"
#FINNHUB_API_KEY=

# Shell-only bootstrap (not read from dotenv): export STOCK_PICKER_ENV_FILE=/path/to/custom.env
